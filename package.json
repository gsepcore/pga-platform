{
  "name": "gsep",
  "version": "0.8.0",
  "private": true,
  "description": "GSEP - Genomic Self-Evolving Prompts | World's First Auto-Evolving AI System",
  "author": "Luis Alfredo Velasquez Duran <contact@gsepcore.com>",
  "license": "SEE LICENSE IN LICENSE",
  "homepage": "https://gsepcore.com",
  "funding": {
    "type": "github",
    "url": "https://github.com/sponsors/gsepcore"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/gsepcore/gsep"
  },
  "keywords": [
    "gsep",
    "prompt-evolution",
    "genomic-prompts",
    "ai-agents",
    "llm",
    "claude",
    "gpt",
    "prompt-engineering",
    "auto-optimization"
  ],
  "workspaces": [
    "packages/*",
    "packages/adapters-llm/*",
    "packages/adapters-storage/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "clean": "turbo run clean && rm -rf node_modules",
    "typecheck": "turbo run typecheck"
  },
  "devDependencies": {
    "@ai-sdk/openai": "^3.0.49",
    "@types/node": "^20.12.7",
    "ai": "^6.0.143",
    "prettier": "^3.2.5",
    "turbo": "^2.0.3",
    "typescript": "^5.9.3"
  },
  "overrides": {
    "esbuild": "^0.25.0",
    "vite": "^6.4.2"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
  "packageManager": "npm@10.5.0",
  "overrides": {
    "hono": ">=4.12.12",
    "@hono/node-server": "1.19.13"
  }
}
