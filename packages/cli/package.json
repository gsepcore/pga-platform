{
  "name": "@gsep/cli",
  "version": "0.8.0",
  "description": "Interactive CLI for GSEP (Genomic Self-Evolving Prompts)",
  "author": "Luis Alfredo Velasquez Duran <contact@gsepcore.com>",
  "license": "MIT",
  "homepage": "https://gsepcore.com",
  "funding": {
    "type": "github",
    "url": "https://github.com/sponsors/gsepcore"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/gsepcore/gsep",
    "directory": "packages/cli"
  },
  "bugs": {
    "url": "https://github.com/gsepcore/gsep/issues"
  },
  "sideEffects": false,
  "type": "module",
  "bin": {
    "pga": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "templates",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "test": "echo \"Tests require external service credentials — see README\" && exit 0",
    "clean": "rm -rf dist",
    "dev": "tsc --watch",
    "start": "node dist/index.js"
  },
  "dependencies": {
    "@gsep/core": "*",
    "commander": "^12.0.0",
    "inquirer": "^9.2.15",
    "chalk": "^5.3.0",
    "ora": "^8.0.1",
    "boxen": "^7.1.1",
    "figlet": "^1.7.0"
  },
  "devDependencies": {
    "@types/node": "^20.12.7",
    "@types/inquirer": "^9.0.7",
    "@types/figlet": "^1.5.8",
    "typescript": "^5.6.0"
  },
  "keywords": [
    "gsep",
    "cli",
    "prompt-evolution",
    "ai-agents",
    "genomic-prompts"
  ],
  "publishConfig": {
    "access": "public"
  }
}
