{
  "name": "@pga-ai/cli",
  "version": "0.1.0",
  "description": "Interactive CLI for PGA (Genomic Self-Evolving Prompts)",
  "author": "Luis Alfredo Velasquez Duran <contact@pga.ai>",
  "license": "MIT",
  "type": "module",
  "bin": {
    "pga": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "templates"
  ],
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf dist",
    "dev": "tsc --watch",
    "start": "node dist/index.js"
  },
  "dependencies": {
    "@pga-ai/core": "*",
    "commander": "^12.0.0",
    "inquirer": "^9.2.15",
    "chalk": "^5.3.0",
    "ora": "^8.0.1",
    "boxen": "^7.1.1",
    "figlet": "^1.7.0"
  },
  "devDependencies": {
    "@types/node": "^20.12.7",
    "@types/inquirer": "^9.0.7",
    "@types/figlet": "^1.5.8",
    "typescript": "^5.6.0"
  },
  "keywords": [
    "pga",
    "cli",
    "prompt-evolution",
    "ai-agents",
    "genomic-prompts"
  ],
  "publishConfig": {
    "access": "public"
  }
}
