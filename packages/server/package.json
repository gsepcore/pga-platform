{
  "name": "@pga-ai/server",
  "version": "0.1.0",
  "description": "GSEP Evolution Server — Secure Pull/Push API for external agents",
  "author": "Luis Alfredo Velasquez Duran <contact@gsepcore.com>",
  "license": "MIT",
  "homepage": "https://gsepcore.com",
  "repository": {
    "type": "git",
    "url": "https://github.com/LuisvelMarketer/pga-platform",
    "directory": "packages/server"
  },
  "bugs": {
    "url": "https://github.com/LuisvelMarketer/pga-platform/issues"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@pga-ai/core": "*",
    "fastify": "^5.3.3",
    "@fastify/rate-limit": "^10.2.0"
  },
  "devDependencies": {
    "typescript": "^5.4.5",
    "vitest": "^3.2.4"
  },
  "publishConfig": {
    "access": "public"
  }
}
