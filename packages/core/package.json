{
  "name": "@pga-ai/core",
  "version": "0.4.0",
  "description": "PGA Core - Genomic Self-Evolving Prompts with Gene Bank, THK, Layered Memory, RAG, and Advanced Reasoning",
  "author": "Luis Alfredo Velasquez Duran <contact@pgacore.com>",
  "license": "MIT",
  "homepage": "https://pgacore.com",
  "repository": {
    "type": "git",
    "url": "https://github.com/pga-ai/pga-platform",
    "directory": "packages/core"
  },
  "keywords": [
    "pga",
    "prompt-evolution",
    "genomic-prompts",
    "ai",
    "llm",
    "agents",
    "prompt-engineering",
    "gene-bank",
    "horizontal-knowledge-transfer",
    "thk",
    "rag",
    "retrieval-augmented-generation",
    "reasoning",
    "chain-of-thought",
    "layered-memory",
    "token-optimization",
    "collective-intelligence"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.12.7",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
