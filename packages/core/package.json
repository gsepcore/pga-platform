{
  "name": "@gsep/core",
  "version": "1.0.3",
  "description": "GSEP Core - Genomic Self-Evolving Prompts with Gene Bank, THK, Layered Memory, RAG, and Advanced Reasoning",
  "author": "Luis Alfredo Velasquez Duran <contact@gsepcore.com>",
  "license": "MIT",
  "homepage": "https://gsepcore.com",
  "funding": {
    "type": "github",
    "url": "https://github.com/sponsors/gsepcore"
  },
  "bugs": {
    "url": "https://github.com/gsepcore/gsep/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/gsepcore/gsep",
    "directory": "packages/core"
  },
  "keywords": [
    "gsep",
    "prompt-evolution",
    "genomic-prompts",
    "ai",
    "llm",
    "agents",
    "prompt-engineering",
    "gene-bank",
    "horizontal-knowledge-transfer",
    "thk",
    "rag",
    "retrieval-augmented-generation",
    "reasoning",
    "chain-of-thought",
    "layered-memory",
    "token-optimization",
    "collective-intelligence"
  ],
  "sideEffects": false,
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./auto": {
      "import": "./dist/auto.js",
      "types": "./dist/auto.d.ts"
    },
    "./engine": {
      "import": "./dist/GSEP.js",
      "types": "./dist/GSEP.d.ts"
    },
    "./security": {
      "import": "./dist/security/index.js",
      "types": "./dist/security/index.d.ts"
    },
    "./vercel-ai": {
      "import": "./dist/adapters/vercel-ai.js",
      "types": "./dist/adapters/vercel-ai.d.ts"
    },
    "./openclaw-plugin": {
      "import": "./dist/adapters/openclaw-plugin.js",
      "types": "./dist/adapters/openclaw-plugin.d.ts"
    },
    "./langchain": {
      "import": "./dist/adapters/langchain.js",
      "types": "./dist/adapters/langchain.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc && cp src/dashboard/dashboard.html dist/dashboard/dashboard.html",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.28.0",
    "better-sqlite3": "^12.8.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20.12.7",
    "@typescript-eslint/eslint-plugin": "^8.57.2",
    "@typescript-eslint/parser": "^8.57.2",
    "@vitest/coverage-v8": "^3.2.4",
    "eslint": "^10.1.0",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
